@page 
@model LogoutModel

@{
    ViewData["Title"] = "Log Out";
}

<h1>@ViewData["Title"]</h1>
@* <form method="post"> <button type="submit" class="btn btn-primary">Log out</button> </form> *@
<div class="row">
    <div class="col-md-4">
        <section>
            <form id="account" method="post">
                <h2>Use SIAL account to log out.</h2>
                <hr />                
                <div>
                    <button id="logout-submit" type="submit" class="w-100 btn btn-lg btn-primary">Log Out</button>
                </div>                
            </form>
        </section>
    </div>
</div>


@using DataAccessLibrary.Models.ViewModels.Export

<div class="card border-0 shadow-sm" style="background: #ffffff; border-radius: 8px;">
    <div class="card-body p-3">
        <h6 class="fw-bold text-dark mb-3">
            <i class="fas fa-file-excel text-primary me-2"></i> Import Order Items from Excel
        </h6>

        <!-- Upload Trigger Section -->
        <div class="card mb-4 border" style="background: #f8f9fb; border-radius: 8px;">
            <div class="card-body py-3">
                <div class="row g-3 align-items-center">
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-secondary mb-1" style="font-size: 0.85rem;">Select Excel File (.xls, .xlsx)</label>
                        <input type="file" class="form-control form-control-sm" accept=".xls,.xlsx" />
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button type="button" class="btn btn-sm btn-success w-100 py-1" style="height: 31px;" @onclick="OnImportTrigger">
                            <i class="fas fa-file-import me-1"></i> Import from Excel
                        </button>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button type="button" class="btn btn-sm btn-outline-primary w-100 py-1" style="height: 31px;">
                            <i class="fas fa-print me-1"></i> Print Import Log
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <!-- 1. Not Found in Company Catalog -->
            <div class="col-md-4">
                <div class="card border-danger h-100">
                    <div class="card-header bg-danger text-white py-2 fw-bold" style="font-size: 0.8rem;">
                        <i class="fas fa-exclamation-triangle me-1"></i> NOT FOUND IN COMPANY CATALOG
                    </div>
                    <div class="card-body p-2" style="max-height: 250px; overflow-y: auto;">
                        <table class="table table-sm table-hover align-middle mb-0" style="font-size: 0.78rem;">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 40px;">S#</th>
                                    <th>Item Code</th>
                                    <th class="text-center">Qty</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ExcelNICompany == null || !ExcelNICompany.Any())
                                {
                                    <tr>
                                        <td colspan="3" class="text-center text-muted py-3">No validation issues.</td>
                                    </tr>
                                }
                                else
                                {
                                    int index = 1;
                                    @foreach (var item in ExcelNICompany)
                                    {
                                        <tr>
                                            <td>@(index++)</td>
                                            <td>@item.ItemCode</td>
                                            <td class="text-center">@item.Qty</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- 2. Not Found in Customer Catalog -->
            <div class="col-md-4">
                <div class="card border-warning h-100">
                    <div class="card-header bg-warning text-dark py-2 fw-bold" style="font-size: 0.8rem;">
                        <i class="fas fa-exclamation-circle me-1"></i> NOT FOUND IN CUSTOMER CATALOG
                    </div>
                    <div class="card-body p-2" style="max-height: 250px; overflow-y: auto;">
                        <table class="table table-sm table-hover align-middle mb-0" style="font-size: 0.78rem;">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 40px;">S#</th>
                                    <th>Item Code</th>
                                    <th class="text-center">Qty</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ExcelNICustomer == null || !ExcelNICustomer.Any())
                                {
                                    <tr>
                                        <td colspan="3" class="text-center text-muted py-3">No validation issues.</td>
                                    </tr>
                                }
                                else
                                {
                                    int index = 1;
                                    @foreach (var item in ExcelNICustomer)
                                    {
                                        <tr>
                                            <td>@(index++)</td>
                                            <td>@item.ItemCode</td>
                                            <td class="text-center">@item.Qty</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="card-footer bg-white border-top-0 p-2">
                        <button type="button" class="btn btn-xs btn-outline-warning w-100 py-1" style="font-size: 0.75rem;" disabled="@(ExcelNICustomer == null || !ExcelNICustomer.Any())">
                            <i class="fas fa-plus me-1"></i> Add to Customer Catalog
                        </button>
                    </div>
                </div>
            </div>

            <!-- 3. OK to Proceed -->
            <div class="col-md-4">
                <div class="card border-success h-100">
                    <div class="card-header bg-success text-white py-2 fw-bold" style="font-size: 0.8rem;">
                        <i class="fas fa-check-circle me-1"></i> OK TO PROCEED
                    </div>
                    <div class="card-body p-2" style="max-height: 250px; overflow-y: auto;">
                        <table class="table table-sm table-hover align-middle mb-0" style="font-size: 0.78rem;">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 40px;">S#</th>
                                    <th>Item Code</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Rate</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ExcelOK == null || !ExcelOK.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-3">No imported items ready.</td>
                                    </tr>
                                }
                                else
                                {
                                    int index = 1;
                                    @foreach (var item in ExcelOK)
                                    {
                                        <tr>
                                            <td>@(index++)</td>
                                            <td>@item.ItemCode</td>
                                            <td class="text-center">@item.Qty</td>
                                            <td class="text-end">@item.Price.ToString("N2")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="card-footer bg-white border-top-0 p-2">
                        <button type="button" class="btn btn-xs btn-outline-success w-100 py-1" style="font-size: 0.75rem;" @onclick="OnAddToOrder" disabled="@(ExcelOK == null || !ExcelOK.Any())">
                            <i class="fas fa-plus me-1"></i> Add Items to Order
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public CustomerOrderViewModel Order { get; set; } = default!;

    [Parameter]
    public List<CustomerOrderItemViewModel> ExcelNICompany { get; set; } = new();

    [Parameter]
    public List<CustomerOrderItemViewModel> ExcelNICustomer { get; set; } = new();

    [Parameter]
    public List<CustomerOrderItemViewModel> ExcelOK { get; set; } = new();

    [Parameter]
    public EventCallback OnImportTrigger { get; set; }

    [Parameter]
    public EventCallback OnAddToOrder { get; set; }
}

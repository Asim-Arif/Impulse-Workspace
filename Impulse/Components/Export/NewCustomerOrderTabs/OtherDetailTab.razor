@using DataAccessLibrary.Models.ViewModels.Export

<div class="card border-0 shadow-sm" style="background: #ffffff; border-radius: 8px;">
    <div class="card-body p-3">
        <h6 class="fw-bold text-dark mb-3">
            <i class="fas fa-info-circle text-primary me-2"></i> Other Details &amp; Packaging
        </h6>

        <div class="row g-3">
            <!-- Special Instructions (maps to txtPackaging in VB6) -->
            <div class="col-md-6">
                <label class="form-label fw-bold text-secondary mb-1" style="font-size: 0.85rem;">Special Instructions</label>
                <textarea class="form-control" rows="8" @bind="Order.Packaging" placeholder="Enter special instructions or packaging requirements..."></textarea>
            </div>

            <!-- Packaging Weight (maps to txtPackagingWeight in VB6) -->
            <div class="col-md-6">
                <label class="form-label fw-bold text-secondary mb-1" style="font-size: 0.85rem;">Packing Weight / Details</label>
                <textarea class="form-control" rows="8" @bind="Order.Packaging_Weight" placeholder="Enter packaging weight and dimension details..."></textarea>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public CustomerOrderViewModel Order { get; set; } = default!;
}

@using DataAccessLibrary.Models.ViewModels.Company
@using Blazored.Typeahead

<div class="row g-4">

    @* ── Row 1: Item Name + Custom Description ── *@
    <div class="col-md-6">
        <label class="form-label fw-bold text-secondary mb-1">Item Name <span class="text-danger">*</span></label>
        <input type="text" class="form-control" @bind="Item.ItemName" placeholder="Enter item name" />
    </div>

    <div class="col-md-6">
        <label class="form-label fw-bold text-secondary mb-1">Custom Description</label>
        <input type="text" class="form-control" @bind="Item.CustomDescription" placeholder="Custom description" />
    </div>

    @* ── Row 2: Unit + Type ── *@
    <div class="col-md-3">
        <label class="form-label fw-bold text-secondary mb-1">Unit <span class="text-danger">*</span></label>
        <BlazoredTypeahead SearchMethod="SearchUnits"
                           EnableDropDown="true"
                           TValue="string"
                           TItem="DataAccessLibrary.Models.ViewModels.Company.UnitModel"
                           Value="Item.Unit"
                           ValueChanged="@(val => Item.Unit = val)"
                           ValueExpression="@(() => Item.Unit)"
                           ConvertMethod="@(u => u?.UnitName)"
                           Placeholder="Select unit"
                           MaximumSuggestions="1000">
            <SelectedTemplate Context="u">@u</SelectedTemplate>
            <ResultTemplate Context="u">@u.UnitName</ResultTemplate>
        </BlazoredTypeahead>
    </div>

    <div class="col-md-3">
        <label class="form-label fw-bold text-secondary mb-1">Type (free text)</label>
        <input type="text" class="form-control" @bind="Item.Type" placeholder="Item type" />
    </div>

    @* ── Row 3: Size + Size Unit + Tip Size ── *@
    <div class="col-md-2">
        <label class="form-label fw-bold text-secondary mb-1">Size</label>
        <input type="text" class="form-control" @bind="Item.ItemSize" placeholder="e.g. 25mm" />
    </div>

    <div class="col-md-2">
        <label class="form-label fw-bold text-secondary mb-1">Size Unit</label>
        <input type="text" class="form-control" @bind="Item.SizeUnit" placeholder="mm / in" />
    </div>

    <div class="col-md-2">
        <label class="form-label fw-bold text-secondary mb-1">Tip Size</label>
        <input type="text" class="form-control" @bind="Item.TipSize" placeholder="Tip size" />
    </div>

    @* ── Row 4: Finish Quality + Color ── *@
    <div class="col-md-4">
        <label class="form-label fw-bold text-secondary mb-1">Finishing Quality</label>
        <input type="text" class="form-control" @bind="Item.FinQuality" placeholder="e.g. Mirror Polish" />
    </div>

    <div class="col-md-4">
        <label class="form-label fw-bold text-secondary mb-1">Color</label>
        <input type="text" class="form-control" @bind="Item.ItemColor" placeholder="Item color" />
    </div>

    @* ── Row 5: Steel Used + Gage ── *@
    <div class="col-md-2">
        <label class="form-label fw-bold text-secondary mb-1">Steel Used</label>
        <input type="number" class="form-control" @bind="Item.SteelUsed" placeholder="Steel ID" />
    </div>

    <div class="col-md-2">
        <label class="form-label fw-bold text-secondary mb-1">Gage</label>
        <input type="text" class="form-control" @bind="Item.Gage" placeholder="Gage" />
    </div>

    @* ── Row 6: Barcodes ── *@
    <div class="col-md-4">
        <label class="form-label fw-bold text-secondary mb-1">Tagging</label>
        <input type="text" class="form-control" @bind="Item.Tagging" placeholder="Tagging barcode" />
    </div>

    <div class="col-md-4">
        <label class="form-label fw-bold text-secondary mb-1">EAN-128</label>
        <input type="text" class="form-control" @bind="Item.EAN128" placeholder="EAN128" />
    </div>

    <div class="col-md-4">
        <label class="form-label fw-bold text-secondary mb-1">GTIN Barcode No.</label>
        <input type="text" class="form-control" @bind="Item.GTINBarcodeNo" placeholder="GTIN" />
    </div>

    @* ── Row 7: UMDNS + Usage ── *@
    <div class="col-md-4">
        <label class="form-label fw-bold text-secondary mb-1">UMDNS Code</label>
        <input type="text" class="form-control" @bind="Item.UMDNSCode" placeholder="UMDNS" />
    </div>

    <div class="col-md-8">
        <label class="form-label fw-bold text-secondary mb-1">Item Usage</label>
        <input type="text" class="form-control" @bind="Item.ItemUsage" placeholder="Intended usage" />
    </div>

    @* ── Row 8: FDA / SFDA ── *@
    <div class="col-12">
        <h6 class="fw-bold text-secondary border-bottom pb-1 mt-2">FDA / SFDA Regulatory</h6>
    </div>

    <div class="col-md-3">
        <label class="form-label fw-bold text-secondary mb-1">FDA Listing No.</label>
        <input type="text" class="form-control" @bind="Item.FDAListingNo" />
    </div>

    <div class="col-md-3">
        <label class="form-label fw-bold text-secondary mb-1">FDA Product Code</label>
        <input type="text" class="form-control" @bind="Item.FDAProductCode" />
    </div>

    <div class="col-md-3">
        <label class="form-label fw-bold text-secondary mb-1">FDA 510K</label>
        <input type="text" class="form-control" @bind="Item.FDA510K" />
    </div>

    <div class="col-md-3">
        <label class="form-label fw-bold text-secondary mb-1">European Reg. No.</label>
        <input type="text" class="form-control" @bind="Item.EuropeanRegNo" />
    </div>

    <div class="col-md-4">
        <label class="form-label fw-bold text-secondary mb-1">SFDA Name</label>
        <input type="text" class="form-control" @bind="Item.SFDA_Name" />
    </div>

    <div class="col-md-4">
        <label class="form-label fw-bold text-secondary mb-1">SFDA No.</label>
        <input type="text" class="form-control" @bind="Item.SFDA_No" />
    </div>

    <div class="col-md-4">
        <label class="form-label fw-bold text-secondary mb-1">SFDA Listing</label>
        <input type="text" class="form-control" @bind="Item.SFDA_Listing" />
    </div>

    @* ── Row 9: Technical / Engineering ── *@
    <div class="col-12">
        <h6 class="fw-bold text-secondary border-bottom pb-1 mt-2">Engineering / Technical</h6>
    </div>

    <div class="col-md-3">
        <label class="form-label fw-bold text-secondary mb-1">Fig. No.</label>
        <input type="text" class="form-control" @bind="Item.Fig_No" />
    </div>

    <div class="col-md-3">
        <label class="form-label fw-bold text-secondary mb-1">Scale</label>
        <input type="text" class="form-control" @bind="Item.Scale" />
    </div>

    <div class="col-md-3">
        <label class="form-label fw-bold text-secondary mb-1">HRC From</label>
        <input type="number" class="form-control" @bind="Item.HRC_From" />
    </div>

    <div class="col-md-3">
        <label class="form-label fw-bold text-secondary mb-1">HRC To</label>
        <input type="number" class="form-control" @bind="Item.HRC_To" />
    </div>

    @* ── Row 10: Stock Levels ── *@
    <div class="col-12">
        <h6 class="fw-bold text-secondary border-bottom pb-1 mt-2">Stock Levels</h6>
    </div>

    <div class="col-md-2">
        <label class="form-label fw-bold text-secondary mb-1">Min Level</label>
        <input type="number" class="form-control" @bind="Item.MinLevel" />
    </div>

    <div class="col-md-2">
        <label class="form-label fw-bold text-secondary mb-1">Max Level</label>
        <input type="number" class="form-control" @bind="Item.MaxLevel" />
    </div>

    <div class="col-md-2">
        <label class="form-label fw-bold text-secondary mb-1">Reorder Level</label>
        <input type="number" class="form-control" @bind="Item.ReOrderLevel" />
    </div>

    <div class="col-md-2">
        <label class="form-label fw-bold text-secondary mb-1">Reorder Point</label>
        <input type="number" class="form-control" @bind="Item.ReorderPoint" />
    </div>

    <div class="col-md-2">
        <label class="form-label fw-bold text-secondary mb-1">Max Lot Size</label>
        <input type="number" class="form-control" @bind="Item.ItemMaxLotSize" />
    </div>

    <div class="col-md-2">
        <label class="form-label fw-bold text-secondary mb-1">Lot Size Buffer</label>
        <input type="number" class="form-control" @bind="Item.ItemLotSizeBuffer" />
    </div>

    @* ── Row 11: Descriptions ── *@
    <div class="col-12">
        <h6 class="fw-bold text-secondary border-bottom pb-1 mt-2">Descriptions</h6>
    </div>

    <div class="col-md-6">
        <label class="form-label fw-bold text-secondary mb-1">Description</label>
        <textarea class="form-control" rows="2" @bind="Item.Description"></textarea>
    </div>

    <div class="col-md-6">
        <label class="form-label fw-bold text-secondary mb-1">Additional Detail</label>
        <textarea class="form-control" rows="2" @bind="Item.Additional_Detail"></textarea>
    </div>

    <div class="col-md-6">
        <label class="form-label fw-bold text-secondary mb-1">Finish Description 1</label>
        <textarea class="form-control" rows="2" @bind="Item.FinishDescription1"></textarea>
    </div>

    <div class="col-md-6">
        <label class="form-label fw-bold text-secondary mb-1">Finish Description 2</label>
        <textarea class="form-control" rows="2" @bind="Item.FinishDescription2"></textarea>
    </div>

    <div class="col-md-6">
        <label class="form-label fw-bold text-secondary mb-1">Maker Description 1</label>
        <textarea class="form-control" rows="2" @bind="Item.MakerDescription1"></textarea>
    </div>

    <div class="col-md-6">
        <label class="form-label fw-bold text-secondary mb-1">Maker Description 2</label>
        <textarea class="form-control" rows="2" @bind="Item.MakerDescription2"></textarea>
    </div>

    <div class="col-12">
        <label class="form-label fw-bold text-secondary mb-1">Maker Description</label>
        <textarea class="form-control" rows="3" @bind="Item.MakerDescription"></textarea>
    </div>

</div>

@code {
    [Parameter, EditorRequired] public ItemDto Item { get; set; } = default!;
    [Parameter, EditorRequired] public List<UnitModel> Units { get; set; } = default!;

    private Task<IEnumerable<UnitModel>> SearchUnits(string searchText) =>
        Task.FromResult(Units.Where(u =>
            u.UnitName.Contains(searchText, StringComparison.OrdinalIgnoreCase)));
}

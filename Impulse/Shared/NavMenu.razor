@using Impulse.Services
@inject IJSRuntime JSRuntime
@inject IReportManagerService ReportManager

<div class="sidebar @(IsSidebarCollapsed ? "collapsed" : "")">
    <div class="sidebar-header p-3 bg-transparent">
        <a class="navbar-brand fw-bold" href="">
            <strong>SIAL ERP</strong>
        </a>
        @* <button class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button> *@
    </div>
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="setup">
                <i class="fas fa-cog me-2"></i> Setups
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/">
                <i class="fas fa-plane me-2"></i> CIP
            </NavLink>
        </div>
        <div class="nav-item px-2">
            <div class="nav-section-header" @onclick="ToggleFinancial">
                <i class="fas fa-chart-line me-2"></i>
                <span>Financial</span>
                <i class="fas fa-chevron-down ms-auto @(isFinancialExpanded ? "rotated" : "")"></i>
            </div>
            @if (isFinancialExpanded)
            {
                <div class="nav-sub-section">
                    <div class="nav-sub-item px-3">
                        <div class="nav-sub-header" @onclick="ToggleAccountSetup">
                            <i class="fas fa-screwdriver-wrench me-2"></i>
                            <span>Account Setup</span>
                            <i class="fas fa-chevron-down ms-auto @(isAccountSetupExpanded ? "rotated" : "")"></i>
                        </div>
                        @if (isAccountSetupExpanded)
                        {
                            <div class="nav-sub-links px-2">
                                <NavLink class="nav-link" href="/accounts/chartofaccounts">
                                    <i class="fas fa-file-invoice me-2"></i> Chart of Accounts
                                </NavLink>
                            </div>
                        }
                    </div>
@* BANK OPTIONS *@
                    <div class="nav-sub-item px-4">
                        <div class="nav-sub-header" @onclick="ToggleBanks">
                            <i class="fas fa-user-tie me-2"></i>
                            <span>Bank Setup</span>
                            <i class="fas fa-chevron-down ms-auto @(isBankSetupExpanded ? "rotated" : "")"></i>
                        </div>
                        @if (isBankSetupExpanded)
                        {
                            <div class="nav-sub-links px-3">
                                <NavLink class="nav-link" href="/accounts/banklist">
                                    <i class="fa fa-university me-2"></i> Bank List
                                </NavLink>
                                <NavLink class="nav-link" href="/accounts/chqbookdetail">
                                    <i class="fa fa-money-check-alt me-2"></i> Bank & Chq Book Detail
                                </NavLink>
                            </div>
                        }
                    </div>
                    <div class="nav-sub-item px-4">
                        <div class="nav-sub-header" @onclick="ToggleVouchers">
                            <i class="fas fa-file-alt me-2" ></i>
                            <span>Vouchers</span>
                            <i class="fas fa-chevron-down ms-auto @(isVouchersExpanded ? "rotated" : "")"></i>
                        </div>
                        @if (isVouchersExpanded)
                        {
                            <div class="nav-sub-links px-2">
                                <NavLink class="nav-link" href="/accounts/cashpaymentvoucher">
                                    <i class="fas fa-money-check-dollar me-2"></i> Cash Payment
                                </NavLink>
                                <NavLink class="nav-link" href="/accounts/bankpaymentvoucher">
                                    <i class="fas fa-money-check me-2"></i> Bank Payment
                                </NavLink>
                                <NavLink class="nav-link" href="/accounts/cashreceiptvoucher">
                                    <i class="fas fa-file-invoice-dollar me-2"></i> Cash Receipt
                                </NavLink>
                                <NavLink class="nav-link" href="/accounts/bankreceiptvoucher">
                                    <i class="fas fa-receipt me-2"></i> Bank Receipt
                                </NavLink>
                                <NavLink class="nav-link" href="/accounts/journalvoucher">
                                    <i class="fas fa-book me-2"></i> Journal Voucher
                                </NavLink>
                                <NavLink class="nav-link" href="/accounts/bodmeetingpayment">
                                    <i class="fas fa-chalkboard-user me-2"></i> BOD Payment
                                </NavLink>
                                <NavLink class="nav-link" href="/accounts/bodmeetingpaymentlist">
                                    <i class="fas fa-list me-2"></i> BOD Payment List
                                </NavLink>
                                <NavLink class="nav-link" href="/accounts/onlinepaymentvoucher">
                                    <i class="fas fa-money-bill-trend-up me-2"></i> Online Payment
                                </NavLink>
                                <NavLink class="nav-link" href="/accounts/onlinepaymentvoucherlist">
                                    <i class="fas fa-list me-2"></i> Online Payment List
                                </NavLink>
                                <NavLink class="nav-link" href="/accounts/onlinetitlesearch">
                                    <i class="fas fa-magnifying-glass me-2"></i> Title Search
                                </NavLink>
                                <NavLink class="nav-link" href="/accounts/voucherslist">
                                    <i class="fas fa-list me-2"></i> Vouchers List
                                </NavLink>
                            </div>
                        }
                    </div>

@* Reports *@
                    <div class="nav-sub-item px-4">
                        <div class="nav-sub-header" @onclick="ToggleReports">
                            <i class="fas fa-user-tie me-2"></i>
                            <span>Reports</span>
                            <i class="fas fa-chevron-down ms-auto @(isBankSetupExpanded ? "rotated" : "")"></i>
                        </div>
                        @if (isReportsExpanded)
                        {
                            <div class="nav-sub-links px-3">
                                <NavLink class="nav-link" href="/accounts/accountsledger">
                                    <i class="fas fa-list me-2"></i> Accounts Ledgder
                                </NavLink>
                                <NavLink class="nav-link" href="/accounts/transactionregister">
                                    <i class="fas fa-list me-2"></i> Transaction Register
                                </NavLink>
                                <NavLink class="nav-link" href="/accounts/trialbalance">
                                    <i class="fas fa-scale-balanced me-2"></i> Trial Balance
                                </NavLink>
                                <NavLink class="nav-link" href="/accounts/bankbalancestatement">
                                    <i class="fas fa-piggy-bank me-2"></i> Bank Balance Statement
                                </NavLink>
                                <NavLink class="nav-link" href="/accounts/cashbookreport">
                                    <i class="fas fa-Rupee-sign me-2"></i> Cash Book Report
                                </NavLink>
                                <button class="nav-link btn btn-link text-start w-100 fw-normal" @onclick='() => ReportManager.RequestReport("vouchers-deleted")'>

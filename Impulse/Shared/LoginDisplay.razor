<AuthorizeView>
    <Authorized>
        @{
            var name = context.User.Identity?.Name ?? "Administrator";
            var initial = !string.IsNullOrEmpty(name) ? name.Substring(0, 1).ToUpper() : "A";
        }
        <div class="login-display-content">
            <div class="md3-user-profile">
                <div class="md3-avatar">@initial</div>
                <div class="md3-user-info">
                    <div class="md3-greeting">@GetGreeting(), @name</div>
                    <div class="md3-subtext">System Administrator &bull; Live Overview</div>
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="d-flex align-items-center login-display-content">
            <a href="/Identity/Account/Register" class="btn btn-outline-primary btn-sm me-2">Register</a>
            <a href="/Identity/Account/Login" class="btn btn-outline-success btn-sm">Log in</a>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private string GetGreeting()
    {
        var hour = DateTime.Now.Hour;
        if (hour < 12)
        {
            return "Good morning";
        }
        else if (hour < 17)
        {
            return "Good afternoon";
        }
        else
        {
            return "Good evening";
        }
    }
}

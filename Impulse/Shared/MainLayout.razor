                };
                await ReportService.PrintReportAsync(req);

                /*isProcessing = false;
                StateHasChanged();*/
                break;
            case "printed-cheque-history":
                res = await rangeModal.Show();
                if (res.Success)
                {
                    /*isProcessing = true;
                    StateHasChanged();*/

                                                                                                                                                                                                                                                                                                                                                                                                                                    req = new ReportRequest
                    {
                        ReportName = ReportNames.PrintedChequeHistory,
                        SelectionFormula = $"{{ChequePrintHistory.PrintDT}} >= #{res.DateFrom:yyyy-MM-dd}# AND {{ChequePrintHistory.PrintDT}} <= #{res.DateTo:yyyy-MM-dd}#"
                    };
                    await ReportService.PrintReportAsync(req);

                    /*isProcessing = false;
                    StateHasChanged();*/
                }
                break;
            case "payable-w.h-tax-report":
                res = await rangeModal.Show();
                if (res.Success)
                {
                    /*isProcessing = true;
                    StateHasChanged();*/
                                                                                                                                                                                                                                                                                                                                                                                                                                    string strDateRange = $"'{res.DateFrom:dd-MMM-yyyy} to {res.DateTo:dd-MMM-yyyy}'";
                    req = new ReportRequest

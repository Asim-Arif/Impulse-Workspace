                        else if (iType == 3)
                            strReportName = ReportNames.CashFlowSummary_Headwise;

                        req = new ReportRequest
                        {

                            ReportName = strReportName,
                            SelectionFormula = $"1=1",

                            Parameters = new Dictionary<string, object>
                            {
                                { "@PrvDTStart", openYear1 },
                                { "@PrvDTEnd", closeYear1 },
                                { "@CurDTStart", openYear2 },
                                { "@CurDTEnd", closeYear2 },
                            },
                            FormulaValues = new Dictionary<string, object>
                            {
                                { "DtFrom",  dtfrom },
                                { "DtTo",    dtto },
                            }
                        };

                        await ReportService.PrintReportAsync(req);

                        isProcessing = false;
                        StateHasChanged();
                    }
                    break;
                }
            case "cash-flow-statement":
                {
                    var rescf_summary = await rangeModal.Show();
                    if (rescf_summary.Success)
                    {
                        isProcessing = true;
                        StateHasChanged();

                        DateTime closeYear1 = new DateTime(rescf_summary.DateFrom.Year, 6, 30);
                        DateTime openYear2 = rescf_summary.DateFrom;
                        DateTime openYear1 = openYear2.AddYears(-1);
                        DateTime closeYear2 = rescf_summary.DateTo;

                        await _financialstatementService.GenerateBalanceSheetReportAsync(rescf_summary.DateFrom, rescf_summary.DateTo);
                        await _financialstatementService.SaveCashFlowStatementToPrint(openYear1,new DateTime(closeYear1.Year, 6, 30),openYear2,closeYear2);
                        await _financialstatementService.SaveCashFlowStatementToPrint(openYear1.AddYears(-1), closeYear1.AddYears(-1), openYear2.AddYears(-1), closeYear2.AddYears(-1), true);

                        
                        string dtfrom = $"'{openYear2:dd-MMM-yyyy}'";
                        string dtto = $"'{closeYear2:dd-MMM-yyyy}'";
                        string Trailas = $"'{closeYear2:d MMM - yyyy}'";
                        string Foryear = $"' FOR THE YEAR ENDED  + {closeYear2:d-mmmm-yyyy}'";

                        double dOpenBal_BB = await DB.getSingleDoubleValueasync("ClBal_Prv", "VCashFlow_SIAL_BankBalance");
                        double dClBal_BB = await DB.getSingleDoubleValueasync("ClBal_Cur", "VCashFlow_SIAL_BankBalance");

                        double dOpenBal_BB_Cur = await DB.getSingleDoubleValueasync("ClBal_Prv_Dr", "VCashFlow_SIAL_BankBalance");
                        double dClBal_BB_Cur = await DB.getSingleDoubleValueasync("ClBal_Cur_Dr", "VCashFlow_SIAL_BankBalance");

                        req = new ReportRequest
                        {

                            ReportName = ReportNames.CashFlowStatement,
                            SelectionFormula = $"1=1",

                            FormulaValues = new Dictionary<string, object>
                            {

                                { "BB_OpenBal",    dOpenBal_BB },
                                { "BB_ClBal",    dClBal_BB },

                                { "OpenBal_BB_Cur",    dOpenBal_BB_Cur },
                                { "ClBal_Cur_Dr",    dClBal_BB_Cur },

                                { "DtFrom",  dtfrom },
                                { "DtTo",    dtto },

                                { "Trailas",  Trailas },
                                { "ForYear",    Foryear },
                            }
                        };

                        await ReportService.PrintReportAsync(req);

                        isProcessing = false;
                        StateHasChanged();
                    }
                    break;
                }
        }
    }

    private async Task<bool> ShowPrompt(string settingName)
    {
        CurrentSetting = settingName;
        IsShowingPrompt = true;
        _tcs = new TaskCompletionSource<bool>();

        // First render shows the modal
        StateHasChanged();

        // Tiny delay to allow the browser to attempt its autofill
        await Task.Delay(50);

        // Now explicitly wipe it again
        UserInput = string.Empty;

        // Second render ensures the UI reflects the empty string
        StateHasChanged();

        return await _tcs.Task;
    }
    private async Task Submit()
    {
        var correctPass = await DB.getDatabasePasswordAsync(CurrentSetting);
        if (UserInput == correctPass)
        {
            IsShowingPrompt = false;
            _tcs.SetResult(true);
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("alert", "Invalid Password");
        }
    }
    private void Cancel()
    {
        IsShowingPrompt = false;
        _tcs.SetResult(false);
    }
    private async Task HandleKeyUp(KeyboardEventArgs e) { if (e.Key == "Enter") await Submit(); }

    private void ToggleSidebar()
    {
        isSidebarCollapsed = !isSidebarCollapsed;
        Console.WriteLine($"Sidebar collapsed: {isSidebarCollapsed}"); // Debug state
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Get window width after render when JS interop is available
                var windowWidth = await JSRuntime.InvokeAsync<int>("getWindowWidth");
                //Console.WriteLine($"Window width: {windowWidth}"); // Debug window width
                if (windowWidth <= 991)
                {
                    isSidebarCollapsed = true; // Collapse sidebar on mobile
                    StateHasChanged(); // Trigger re-render
                }
            }
            catch (Exception ex)
            {
                // Handle potential JS interop errors
                Console.WriteLine($"JS Interop error: {ex.Message}");
            }
        }
    }
}
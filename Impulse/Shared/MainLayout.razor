            case "tax-reports":

                AccountHeads = await DB.GetListAsync<GenericDropDownModel>("'{ ' + AccNo + ' } ' + AccTitle AS DropDownValue_Description,AccNo AS DropDownValue_ID", "VAccounts_Parent");
                AccountHeads.Insert(0, new GenericDropDownModel

                    };
                    await ReportService.PrintReportAsync(req);

                }
                break;  

            case "capital-work-inprogress":
                res = await rangeModal.Show();
                if (res.Success)
                {
                    string strDateRange = $"'{res.DateFrom:dd-MMM-yyyy} to {res.DateTo:dd-MMM-yyyy}'";
                    string dtfrom = $"'{res.DateFrom:dd-MMM-yyyy}'";
                    string dtto = $"'{res.DateTo:dd-MMM-yyyy}'";

                    // Extract local variables from the "bag"
                    int iType = GetArg("ssiType", 1);
                    bool withInfant = GetArg("withInfant", false);

                    req = new ReportRequest
                    {
                        ReportName = $"CapitalWorkInProgress.rpt",
                        Parameters = new Dictionary<string, object>
                        {
                            { "@CurDTStart", res.DateFrom },
                            { "@CurDTEnd", res.DateTo }
                        },
                        FormulaValues = new Dictionary<string, object>
                        {
                            { "DateRange", strDateRange },
                            { "DtFrom", dtfrom },
                            { "DtTo", dtto }
                        }

                    };
                    await ReportService.PrintReportAsync(req);
                }
                break;
            case "sub-heads-reports":

                AccountHeads = await DB.GetListAsync<GenericDropDownModel>("GroupName +' { ' + 'Note No. ' + CAST(SortNo AS VARCHAR(50)) + ' } ' AS DropDownValue_Description,EntryID AS DropDownValue_ID", "GroupsForFinancialReport", " ORDER BY GroupsForFinancialReport.EntryID");
                AccountHeads.Insert(0, new GenericDropDownModel
                {
                    DropDownValue_ID = "0",
                    DropDownValue_Description = "< All Main Heads >"
                });

                AccountHeads_sub = await DB.GetListAsync<GenericDropDownModel>("GroupName +' { ' + 'Note No. ' + Notes + ' } ' AS DropDownValue_Description,EntryID AS DropDownValue_ID", "GroupsForFinancialReport_Sub", " ORDER BY GroupsForFinancialReport_Sub.EntryID");
                AccountHeads_sub.Insert(0, new GenericDropDownModel
                {
                    DropDownValue_ID = "0",
                    DropDownValue_Description = "< All Sub Heads >"
                });

                res = await dateRangeModalWithSubHeadsSelect.Show(AccountHeads, AccountHeads_sub, "Print Sub Heads Reports");


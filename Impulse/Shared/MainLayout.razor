            case "aging-report":

                AccountHeads = await DB.GetListAsync<GenericDropDownModel>("AccTitle AS DropDownValue_Description,AccNo AS DropDownValue_ID", "Accounts", "WHERE Active=1 AND Parent=1");
                AccountHeads.Insert(0, new GenericDropDownModel
                {
                    DropDownValue_ID = "0",
                    DropDownValue_Description = "-- All Accounts --"
                });

                res = await dateRangeModalWithSingleSelect.Show(AccountHeads, "Aging Report");

                if (res.Success)
                {
                    string strDateRange = $"'{res.DateFrom:dd-MMM-yyyy} to {res.DateTo:dd-MMM-yyyy}'";

                    req = new ReportRequest
                    {
                        ReportName = ReportNames.AccountsAgingReport,

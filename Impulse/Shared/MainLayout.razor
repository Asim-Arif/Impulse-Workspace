@using Impulse.Shared.Components
@using Impulse.Services
@using Impulse.Constants
@using DataAccessLibrary.Models.ViewModels
@inherits LayoutComponentBase
@implements IDisposable
@inject IJSRuntime JSRuntime
@inject IReportManagerService ReportManager
@inject IReportNavigationService ReportService
@inject LoadingService LoadingService
@inject SecurityService SecurityService
@inject IDBHelperService DB

<PageTitle>CIP</PageTitle>

<div class="layout">
    <div class="sidebar-container">
        <NavMenu IsSidebarCollapsed="@isSidebarCollapsed" OnToggleSidebar="ToggleSidebar" />
    </div>
    <main class="@(isSidebarCollapsed ? "collapsed" : "")">
        <div class="top-row px-0 auth">
            <LoginDisplay />
        </div>
        @* <article class="content px-4"> *@
        <article class="content">
            @Body
        </article>
    </main>
    <RadzenNotification />
</div>

@* These modals sit on top of the whole app *@
<DateRangeModal @ref="rangeModal" />
<DateSingleModal @ref="singleModal" />
<DateRangeWithSingleSelectModal @ref="dateRangeModalWithSingleSelect" />
<DateRangeWithSubHeadsSelectModal @ref="dateRangeModalWithSubHeadsSelect" />

@if (isProcessing)
{
    <div class="cip-rpt-loading-screen">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
        <h4 class="mt-4 text-dark fw-bold">Loading</h4>
        <p class="text-muted">Please wait, your document is being prepared...</p>
    </div>
}
@if (isVisible)
{
    <div class="cip-rpt-loading-screen">
        <div class="data-flow-container">
            <div class="flow-node database">
                <i class="fa fa-database"></i>
                <span class="node-label">SQL DATA</span>
            </div>

            <div class="flow-path-short">
                <div class="data-bit">1011</div>
                <div class="data-bit d1">0101</div>
            </div>

            <div class="flow-node processor">
                <i class="fa fa-cog fa-spin-slow"></i>
                <span class="node-label">PROCESSING</span>
            </div>

            <div class="flow-path-short">
                <div class="file-fragment">
                    <i class="fa-solid fa-file-circle-plus"></i>
                </div>
                <div class="file-fragment d2">
                    <i class="fa-solid fa-file-lines"></i>
                </div>
            </div>

            <div class="flow-node document">
                <i class="fa-solid fa-file-lines pdf-icon-color"></i>
                <span class="node-label">PDF REPORT</span>
            </div>
        </div>

        <div class="loader-text mt-4">
            <h4 class="text-dark fw-bold">Processing Report</h4>
            <p class="text-muted">@loadingMessage</p>
        </div>
    </div>
}
@if (IsShowingPrompt)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5); z-index: 3000;">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content shadow-lg border-primary">
                <div class="modal-header py-2 theme-color text-white">
                    <h6 class="mb-0">Security Authorization</h6>
                </div>
                <div class="modal-body">
                    <input type="text" style="display:none;" tabindex="-1" />
                    <input type="password" style="display:none;" tabindex="-1" />

                    <label class="small fw-bold">Enter Password</label>
                    <input type="password"
                           class="form-control mt-1"
                           @bind="UserInput"
                           @bind:event="oninput"
                           @onkeyup="HandleKeyUp"
                           autocomplete="new-password" />
                </div>
                <div class="modal-footer py-1">
                    <button class="btn btn-sm btn-primary" @onclick="Submit">OK</button>
                    <button class="btn btn-sm btn-secondary" @onclick="Cancel">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}
@code {

    private bool IsShowingPrompt = false;
    private string UserInput = "";
    private string CurrentSetting = "";
    private TaskCompletionSource<bool> _tcs;
    private ElementReference passwordInput;

    private bool isVisible;
    private string loadingMessage = "";
    private bool isSidebarCollapsed = false;

    private DateRangeModal rangeModal;
    private DateSingleModal singleModal;
    private DateRangeWithSingleSelectModal dateRangeModalWithSingleSelect;
    private DateRangeWithSubHeadsSelectModal dateRangeModalWithSubHeadsSelect;
    private bool isProcessing = false;
    [Inject]
    private IFinancialStatementService _financialstatementService { get; set; }

    protected override void OnInitialized()
    {
        // Listen for report requests from the NavMenu
        LoadingService.OnLoadingStateChanged += HandleLoading;
        ReportManager.OnRequestReport += HandleReportRequest;
        SecurityService.OnPasswordRequest += ShowPrompt;
    }
    private void HandleLoading(bool visible, string message)
    {
        isVisible = visible;
        loadingMessage = message;
        InvokeAsync(StateHasChanged);
    }
    public void Dispose()
    {
        // Unsubscribe to stay clean
        ReportManager.OnRequestReport -= HandleReportRequest;
        LoadingService.OnLoadingStateChanged -= HandleLoading;
        SecurityService.OnPasswordRequest -= ShowPrompt;
    }
    private async void HandleReportRequest(string key, IDictionary<string, object>? extraArgs)
    {
        dynamic res, req;
        string reportName = "";
        string selectionFormula = "";
        List<GenericDropDownModel> AccountHeads = new();
        List<GenericDropDownModel> AccountHeads_sub = new();
        // Helper to get values from extraArgs safely
        T GetArg<T>(string name, T defaultValue) =>
            (extraArgs != null && extraArgs.TryGetValue(name, out var val)) ? (T)val : defaultValue;

        switch (key.ToLower())
        {
            case "vouchers-deleted":
                res = await rangeModal.Show();
                if (res.Success)
                {
                    /*isProcessing = true;
                    StateHasChanged();*/

                                                                                                                                                                                                                                                                                                                                                                                                                                    req = new ReportRequest
                    {
                        ReportName = ReportNames.EditedVouchers,
                        SelectionFormula = $"{{VouchersDeleted.VDate}} >= #{res.DateFrom:yyyy-MM-dd}# AND {{VouchersDeleted.VDate}} <= #{res.DateTo:yyyy-MM-dd}#"
                    };
                    await ReportService.PrintReportAsync(req);

                    /*isProcessing = false;
                    StateHasChanged();*/
                }
                break;
            case "cost_center_report":
                res = await rangeModal.Show();
                if (res.Success)
                {
                    /*isProcessing = true;
                    StateHasChanged();*/

                                                                                                                                                                                                                                                                                                                                                                                                                                    req = new ReportRequest
                    {
                        ReportName = ReportNames.CostCenterReport,
                        Parameters = new Dictionary<string, object>
                        {
                            { "@DTFrom", res.DateFrom },
                            { "@DTTo", res.DateTo }
                        }
                    };
                    await ReportService.PrintReportAsync(req);

                    /*isProcessing = false;
                    StateHasChanged();*/
                }
                break;
            case "accounts-breakup":

                /*isProcessing = true;
                StateHasChanged();*/

                                                                                                                                                                                                                                                                                                                                                req = new ReportRequest

                    {
                        /// do nothing
                    }
                    else if ((strMainHeadsEntryID != "0") && (strSubHeadsEntryID == "0"))
                    {
                        strcond = strcond + $" AND {{BalanceSheet.EntryID}}= {strMainHeadsEntryID}";
                    }
                    else if ((strMainHeadsEntryID == "0") && (strSubHeadsEntryID != "0"))
                    {
                        strcond = strcond + $" AND {{BalanceSheet.SubEntryID}}= {strSubHeadsEntryID}";
                    }
                    else if ((strMainHeadsEntryID != "0") && (strSubHeadsEntryID != "0"))
                    {
                        strcond = strcond + $" AND {{BalanceSheet.EntryID}}= {strMainHeadsEntryID} AND {{BalanceSheet.SubEntryID}}= {strSubHeadsEntryID}";
                    } 
                    else
                    {
                        strcond = strcond + $" AND {{BalanceSheet.SubEntryID}}= {strSubHeadsEntryID}";

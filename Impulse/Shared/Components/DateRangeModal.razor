@using DataAccessLibrary.Models.ReportModels
@if (IsVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5); z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content cip-rpt-modal-content">
                <div class="modal-header cip-rpt-header d-flex align-items-center justify-content-between">
                    <h5 class="modal-title text-white">
                        <i class="fa fa-calendar me-2"></i>Select Date Range
                    </h5>
                    <button type="button" class="btn btn-sm p-0 border-0" @onclick="Cancel">
                        <span class="cip-rpt-close-x">&times;</span>
                    </button>
                </div>

                <div class="modal-body p-4">
                    <div class="cip-rpt-date-display text-center mb-4">
                        <div class="row align-items: center;">
                            <div class="col">
                                <small class="text-uppercase text-muted fw-normal" style="font-size: 0.7rem; letter-spacing: 1px; opacity: 0.8;">
                                    From Date
                                </small>
                                <h5 class="text-primary mb-0">@DateFrom.ToString("dd-MMM-yyyy")</h5>
                            </div>
                            <div class="col-auto">
                                <i class="fa-solid fa-arrow-right text-muted" style="font-size: 0.8rem;"></i>
                            </div>
                            <div class="col">
                                <small class="text-uppercase text-muted fw-normal" style="font-size: 0.7rem; letter-spacing: 1px; opacity: 0.8;">
                                    To Date
                                </small>
                                <h5 class="text-primary mb-0">@DateTo.ToString("dd-MMM-yyyy")</h5>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="mb-1 fw-bold" style="font-size: 0.85rem;">Start Date:</label>
                            <input type="date" class="form-control cip-rpt-input-custom" @bind="DateFrom" />
                        </div>
                        <div class="col-md-6">
                            <label class="mb-1 fw-bold" style="font-size: 0.85rem;">End Date:</label>
                            <input type="date" class="form-control cip-rpt-input-custom" @bind="DateTo" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer border-0 bg-light">
                    <button class="btn btn-outline-secondary border-0" @onclick="Cancel">Cancel</button>
                    <button class="btn btn-primary px-4 fw-bold shadow-sm" style="border-radius: 8px;" @onclick="Submit">
                        Generate Report
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool IsVisible { get; set; }
    private DateTime DateFrom { get; set; } = DateTime.Today.AddDays(-30); // Default to last 30 days    
    private DateTime DateTo { get; set; } = DateTime.Today;
    private TaskCompletionSource<DateRangeResult> _tcs;

    public Task<DateRangeResult> Show()
    {
        IsVisible = true;
        _tcs = new TaskCompletionSource<DateRangeResult>();
        StateHasChanged();
        return _tcs.Task;
    }

    private void Submit()
    {
        IsVisible = false;
        _tcs.SetResult(new DateRangeResult(true, DateFrom, DateTo));
    }
    private void Cancel()
    {
        IsVisible = false;
        _tcs.SetResult(new DateRangeResult(false, DateTime.MinValue, DateTime.MinValue));
    }
    
}
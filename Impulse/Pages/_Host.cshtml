@page "/"
@namespace Impulse.Pages

@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;    
}
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SIAL ERP</title>
    <base href="/" />
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Font Awesome (icons) -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
    <!-- Blazored Typeahead CSS -->
    <link href="/_content/Blazored.Typeahead/blazored-typeahead.css" rel="stylesheet" />

    <!-- Your site styles (MUST come last to override Bootstrap) -->
    <link href="/css/site.css" rel="stylesheet" />

    <link href="_content/Blazor.ContextMenu/blazorContextMenu.min.css" rel="stylesheet" />    
    
    @* <script src="_content/BlazorContextMenu/blazorContextMenu.js"></script> *@
    @* <script src="js/contextMenu.js"></script> *@

    @* <link href="_content/BlazorBootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <script src="_content/BlazorBootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="_framework/blazor.server.js"></script>
    <script src="_content/BlazorBootstrap/js/bootstrap.bundle.min.js"></script> *@

</head>

<body>
    <app>
        <component type="typeof(App)" render-mode="ServerPrerendered" />
    </app>

    <!-- Blazor framework -->
    <script src="/_framework/blazor.server.js"></script>

    <!-- Bootstrap Bundle (includes Popper) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Blazored Typeahead -->
    <script src="/_content/Blazored.Typeahead/blazored-typeahead.js"></script>

    <!-- Your custom JS -->
    <script src="/scripts.js"></script>
    <script src="/js/site.js"></script>
    <script src="/js/pdfHelper.js"></script>
    <script src="_content/Blazor.ContextMenu/blazorContextMenu.min.js"></script>

    <script>
        window.showBootstrapModal = (el) => {
            var modal = new bootstrap.Modal(el);
            modal.show();
            el._modalInstance = modal;
        };

        window.hideBootstrapModal = (el) => {
            if (el._modalInstance) {
                el._modalInstance.hide();
            }
        };
    </script>

    

</body>
</html>

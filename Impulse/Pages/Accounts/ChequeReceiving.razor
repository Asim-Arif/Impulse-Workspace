@page "/accounts/chequereceiving"
@attribute [Authorize]
<PageTitle>Cheque Receiving Report</PageTitle>

@using System.Collections.ObjectModel
@using Microsoft.AspNetCore.Components.Web
@using BlazorContextMenu
@using Microsoft.Extensions.Options
@using DataAccessLibrary
@using DataAccessLibrary.Models.ViewModels.Accounts
@using DataAccessLibrary.Models.ViewModels
@using Impulse.Configurations
@using DataAccessLibrary.Interface.Accounts
@using Microsoft.AspNetCore.Components.Web.Virtualization
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div class="container-fluid mt-0 m-0 p-0" style="font-family: Calibri, sans-serif;">
    
    <div class="card-header text-white d-flex justify-content-between align-items-center rounded-top-4 px-3 py-2 theme-color"
         style="position: sticky; top: 0; z-index: 1000;">
        <h5 class="mb-0"><i class="fas fa-file-lines"></i> Cheque Receiving Report</h5>
        <div class="d-flex align-items-center gap-2">
            <button class="btn btn-light btn-sm fw-semibold" @onclick="GoToIndexPage">
                <i class="fas fa-xmark me-2"></i> Close
            </button>
        </div>
    </div>

    <div class="card-body report-flex-column">

        <div class="row g-1 mb-2 align-items-end">
            <div class="col-sm-2">
                <label for="Range" class="form-label mb-0 fw-bold">Range</label>
                <select id="Range" class="form-select py-1" value="@SelectedRangeValue" @onchange="OnRangeChanged">
                    <option value="0">Today</option>
                    <option value="1">Last 15 Days</option>
                    <option value="2">Last 30 Days</option>
                    <option value="3">Last 60 Days</option>
                    <option value="4">Last 90 Days</option>
                    <option value="5">Last 180 Days</option>
                    <option value="6">Date Range</option>
                </select>
            </div>
            <div class="col-sm-2">
                <label for="fromDate" class="mb-0 fw-bold">From</label>
                <input type="date" id="fromDate" class="form-control form-control-md" @bind="DTFrom" disabled="@(SelectedRangeValue != "6")" />
            </div>
            <div class="col-sm-2">
                <label for="toDate" class="fw-bold">To</label>
                <input type="date" id="toDate" class="form-control form-control-md" @bind="DTTo" disabled="@(SelectedRangeValue != "6")" />
            </div>
            <div class="col-sm-1 d-flex align-items-end">
                <button class="btn btn-primary btn-sm w-100 text-white" style="background-color:rgb(7, 44, 96);" @onclick="RefreshList">
                    <i class="fas fa-sync-alt me-1"></i>Refresh
                </button>
            </div>
        </div>

        @if (IsLoading)
        {
            <div class="progress mb-2" style="width: 100%; height: 20px;">
                <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary" role="progressbar" style="width: 100%">
                    Loading Data...
                </div>
            </div>
        }

        <div class="report-table-grow sticky-table-container">
            <ContextMenuProvider Id="accountsContext">
                <table class="table table-bordered table-hover align-middle mb-0" 
                       style="font-family: Calibri, 'Segoe UI', Tahoma, sans-serif; font-size: 10pt;">
                    <thead class="theme-color" style="position: sticky; top: 0; z-index: 5;">
                        <tr>
                            <th style="width: 3%;">S #</th>
                            <th style="width: 7%;">Date</th>
                            <th style="width: 30%;">Party Name</th>
                            <th style="width: 10%;">Chq / DD#</th>
                            <th style="width: 10%;">Deposit Bank</th>
                            <th style="width: 10%;" class="text-center">Amount</th>
                            <th style="width: 14%;">Department</th>
                            <th style="width: 14%;">Employee</th>
                            <th style="width: 2%;"> </th>
                        </tr>
                    </thead>
                    <tbody style="font-family: Calibri, 'Segoe UI'; font-size: 9pt;">
                        @if (ListToUse?.Any() ?? false)
                        {
                            <Virtualize Items="@ListToUse" Context="row">
                                <ContextMenuTrigger WrapperTag="tr" MenuId="accountContextMenu" Data="row" MouseButtonTrigger="MouseButtonTrigger.Right" CssClass="@($"key-{row.EntryID}")">
                                    <td>@(ListToUse.IndexOf(row) + 1)</td>
                                    <td>@row.DT.ToString("dd-MMM-yyyy")</td>
                                    <td>@row.PartyName</td>
                                    <td>@row.ChqNo</td>
                                    <td>@row.DepositBank</td>
                                    <td class="text-center">@row.Amount.ToString("N0")</td>
                                    <td>@row.DeptName</td>
                                    <td>@row.Name</td>
                                    <td>

                                        <ContextMenuTrigger MenuId="accountContextMenu"
                                                            Data="row"
                                                            MouseButtonTrigger="MouseButtonTrigger.Both">

                                            <button class="btn btn-sm btn-primary" style="border:none; background:none;">

                                                <i class="fa-solid fa-ellipsis-vertical" style="color:black"></i>

                                            </button>

                                        </ContextMenuTrigger>

                                    </td>
                                </ContextMenuTrigger>
                            </Virtualize>
                        }
                        else if (!IsLoading)
                        {
                            @* Shows when list is empty to maintain table structure *@
                            <tr>
                                <td colspan="9" class="text-center py-5 text-muted italic">
                                    <i class="fas fa-inbox fa-3x d-block mb-3"></i>
                                    No entries found for the selected period.
                                </td>
                            </tr>
                            @* Optional: Render 5 blank rows to show the grid lines *@
                            @for (int i = 0; i < 15; i++)
                            {
                                <tr><td colspan="9" style="height:35px; border-color: #f2f2f2;">&nbsp;</td></tr>
                            }
                        }
                    </tbody>
                </table>
            </ContextMenuProvider>
        </div>

        <div class="report-footer-actions d-flex justify-content-end gap-2">
            
            <button class="btn btn-outline-success btn-sm px-3" @onclick="OpenAddNew">
                <i class="fas fa-plus me-1"></i> New Entry
            </button>

            <button class="btn btn-outline-success btn-sm px-3" @onclick="PrintReport">
                <i class="fas fa-print me-1"></i> Print
            </button>

        </div>

    </div>

    <ContextMenu Id="accountContextMenu" Template="Win11Style">
        <Item Onclick="@RefreshList"><i class="fas fa-sync-alt fa-fw win11-icon"></i> Refresh</Item>
        <div class="menu-divider"></div>
        <Seperator />
        <Item Onclick="OpenAddNew"><i class="fas fa-plus fa-fw win11-icon"></i> New Entry</Item>
        <Item Onclick="@(() => OpenEdit(context.Data as Cheque_Receiving_ViewModel))"><i class="fas fa-i-cursor fa-fw win11-icon"></i> Edit Entry</Item>
        <Item Onclick="@(()=> DeleteEntry(context.Data as Cheque_Receiving_ViewModel))"><i class="fas fa-trash fa-fw win11-icon"></i> Delete Entry</Item>
        <div class="menu-divider"></div>
        <Seperator />
        <Item Onclick="PrintReport"><i class="fas fa-print fa-fw win11-icon"></i> Print Report</Item>
    </ContextMenu>
</div>

<div class="modal fade @(ShowModal ? "show d-block" : "")" tabindex="-1" role="dialog" style="background: rgba(0,0,0,0.5);">
    <div class="modal-dialog modal-lg modal-erp" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title fw-bold">Cheque Receiving</h6>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>
            <EditForm Model="@CurrentEntry" OnValidSubmit="SaveEntry">                
            <DataAnnotationsValidator />
            <div class="modal-body p-3">
                <div class="row g-2">
                    <div class="col-md-3">
                        <label class="form-label">Receiving Date</label>
                        <input type="date" class="form-control" @bind="CurrentEntry.DT" />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Party Name</label>
                        <input type="text" class="form-control" @bind="CurrentEntry.PartyName" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Received From</label>
                        <input type="text" class="form-control" @bind="CurrentEntry.ReceivedFrom" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Chq / DD No.</label>
                        <input type="text" class="form-control" @bind="CurrentEntry.ChqNo" />
                    </div>
                    <div class="col-md-8">
                        <label class="form-label">Deposit Bank</label>
                        <input type="text" class="form-control" @bind="CurrentEntry.DepositBank" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Cheque Date</label>
                        <input type="date" class="form-control" @bind="CurrentEntry.DTChq" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Amount</label>
                        <input type="number" class="form-control text-end" @bind="CurrentEntry.Amount" @bind:event="oninput" />
                        <ValidationMessage For="@(() => CurrentEntry.Amount)" class="text-danger small" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Bank Slip No.</label>
                        <input type="text" class="form-control" @bind="CurrentEntry.SlipNo" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Slip Date</label>
                        <input type="date" class="form-control" @bind="CurrentEntry.DTSlip" />
                    </div>

                    <div class="col-md-12 mt-2">
                        <label class="form-label">Employee</label>
                        <div class="erp-typeahead">
                            <BlazoredTypeahead SearchMethod="SearchEmployees"
                                               @bind-Value="SelectedEmployee"
                                               Placeholder="Search by name or code..."
                                               EnableDropDown="true"
                                               ShowDropDownOnFocus="true">
                                <SelectedTemplate Context="emp">
                                    @emp.DropDownValue_Description
                                </SelectedTemplate>
                                <ResultTemplate Context="emp">
                                    @emp.DropDownValue_Description (@emp.DropDownValue_ID)
                                </ResultTemplate>
                                <NotFoundTemplate Context="emp">
                                    No employee found.
                                </NotFoundTemplate>
                            </BlazoredTypeahead>
                            <ValidationMessage For="@(() => CurrentEntry.EmpID)" class="text-danger small" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light py-1">
                <button type="submit" class="btn btn-outline-secondary px-4 shadow-sm"><u>S</u>ave</button>
                <button type="button" class="btn btn-outline-secondary px-4 shadow-sm" @onclick="CloseModal"><u>C</u>ancel</button>
            </div>
            </EditForm>
        </div>
    </div>
</div>
@page "/export"
@attribute [Authorize]

<PageTitle>Export Dashboard</PageTitle>

<div class="dashboard-shell">
    <div class="dashboard-hero">
        <div class="dashboard-icon-wrap" style="background:#fce8d0; color:#7a3000;">
            <i class="fas fa-ship"></i>
        </div>
        <div>
            <h1 class="dashboard-title">Export</h1>
            <p class="dashboard-subtitle">Foreign customers &amp; export operations</p>
        </div>
    </div>

    <div class="dashboard-modules">
        <a href="/export/customers" class="dash-card">
            <i class="fas fa-users"></i>
            <span>Foreign Customers</span>
        </a>
        <a href="/export/customer" class="dash-card">
            <i class="fas fa-user-plus"></i>
            <span>New Customer</span>
        </a>
        <a href="/export/new-customer-order" class="dash-card">
            <i class="fas fa-file-invoice"></i>
            <span>New Customer Order</span>
        </a>
        <a href="/export/customer-order-list" class="dash-card">
            <i class="fas fa-list-alt"></i>
            <span>Customer Order List</span>
        </a>
    </div>
</div>

<style>
    .dashboard-shell { padding: 2rem; max-width: 1100px; }
    .dashboard-hero { display: flex; align-items: center; gap: 1.25rem; margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 2px solid #e0e2ec; }
    .dashboard-icon-wrap { width: 64px; height: 64px; border-radius: 18px; display: flex; align-items: center; justify-content: center; font-size: 1.75rem; flex-shrink: 0; }
    .dashboard-title { font-size: 2rem; font-weight: 700; color: #1b1b1f; margin: 0; line-height: 1.2; }
    .dashboard-subtitle { color: #44474f; margin: 0.25rem 0 0; font-size: 0.95rem; }
    .dashboard-modules { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 1rem; }
    .dash-card { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.75rem; padding: 1.5rem 1rem; background: #ffffff; border: 1px solid #e0e2ec; border-radius: 16px; text-decoration: none; color: #1b1b1f; font-weight: 500; font-size: 0.875rem; text-align: center; transition: background-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease; cursor: pointer; }
    .dash-card i { font-size: 1.75rem; color: #c05800; }
    .dash-card:hover { background: #fff4ed; box-shadow: 0 4px 16px rgba(192, 88, 0, 0.12); transform: translateY(-2px); color: #7a3000; }
    .dash-card:hover i { color: #7a3000; }
</style>

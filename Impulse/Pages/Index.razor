@page "/"
@attribute [Authorize]
@inject Impulse.Services.IDBHelperService DbHelper

<PageTitle>Master Dashboard — SIAL ERP</PageTitle>

<div class="master-dashboard">

    <!-- Hero Header -->
    <div class="master-hero">
        <div class="master-hero-text">
            <h1 class="master-title">Master Dashboard</h1>
            <p class="master-subtitle">Overview of all ERP modules — click any card to navigate</p>
        </div>
        <div class="master-hero-badge">
            <i class="fas fa-layer-group"></i>
        </div>
    </div>

    <!-- Module Cards Grid -->
    <div class="module-grid">

        <a href="/company/items" class="module-card company">
            <div class="module-card-icon">
                <i class="fas fa-building"></i>
            </div>
            <div class="module-card-body">
                <h2 class="module-card-title">Company / Items</h2>
                <p class="module-card-desc">Company profile, items master &amp; catalog lists</p>
                <div class="module-card-metrics">
                    <span class="metric-item"><i class="fas fa-box me-1"></i> @totalActiveItems Active Items</span>
                    <span class="metric-separator">•</span>
                    <span class="metric-item @(lowStockAlerts > 0 ? "text-danger fw-bold" : "")">
                        <i class="fas fa-triangle-exclamation me-1"></i> @lowStockAlerts Low Stock
                    </span>
                </div>
            </div>
            <div class="module-card-arrow">
                <i class="fas fa-arrow-right"></i>
            </div>
        </a>

        <a href="/financial" class="module-card financial">
            <div class="module-card-icon">
                <i class="fas fa-chart-line"></i>
            </div>
            <div class="module-card-body">
                <h2 class="module-card-title">Financial</h2>
                <p class="module-card-desc">Vouchers, ledgers, trial balance &amp; financial statements</p>
            </div>
            <div class="module-card-arrow">
                <i class="fas fa-arrow-right"></i>
            </div>
        </a>

        <a href="/payroll" class="module-card payroll">
            <div class="module-card-icon">
                <i class="fas fa-users-gear"></i>
            </div>
            <div class="module-card-body">
                <h2 class="module-card-title">Payroll</h2>
                <p class="module-card-desc">Employees, departments &amp; payroll processing</p>
            </div>
            <div class="module-card-arrow">
                <i class="fas fa-arrow-right"></i>
            </div>
        </a>

        <a href="/export" class="module-card export">
            <div class="module-card-icon">
                <i class="fas fa-ship"></i>
            </div>
            <div class="module-card-body">
                <h2 class="module-card-title">Export</h2>
                <p class="module-card-desc">Foreign customers &amp; export operations</p>
            </div>
            <div class="module-card-arrow">
                <i class="fas fa-arrow-right"></i>
            </div>
        </a>

        <a href="/stock" class="module-card stock">
            <div class="module-card-icon">
                <i class="fas fa-boxes-stacked"></i>
            </div>
            <div class="module-card-body">
                <h2 class="module-card-title">Stock</h2>
                <p class="module-card-desc">Inventory management &amp; stock operations</p>
            </div>
            <div class="module-card-arrow">
                <i class="fas fa-arrow-right"></i>
            </div>
        </a>

        <a href="/production" class="module-card production">
            <div class="module-card-icon">
                <i class="fas fa-industry"></i>
            </div>
            <div class="module-card-body">
                <h2 class="module-card-title">Production</h2>
                <p class="module-card-desc">Manufacturing orders &amp; production tracking</p>
            </div>
            <div class="module-card-arrow">
                <i class="fas fa-arrow-right"></i>
            </div>
        </a>

        <a href="setup" class="module-card setups">
            <div class="module-card-icon">
                <i class="fas fa-cog"></i>
            </div>
            <div class="module-card-body">
                <h2 class="module-card-title">Setups</h2>
                <p class="module-card-desc">System configuration &amp; application settings</p>
            </div>
            <div class="module-card-arrow">
                <i class="fas fa-arrow-right"></i>
            </div>
        </a>

    </div>
</div>

@code {
    private int totalActiveItems = 0;
    private int lowStockAlerts = 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Retrieve dynamic metrics from database
            totalActiveItems = await DbHelper.getSingleIntValueasync("COUNT(*)", "VItems", "WHERE InActive = 0");
            lowStockAlerts = await DbHelper.getSingleIntValueasync("COUNT(*)", "VItems", "WHERE InHand < ReorderPoint AND InActive = 0");
        }
        catch
        {
            // Fallbacks in case database connection fails during startup
            totalActiveItems = 1672;
            lowStockAlerts = 1;
        }
    }
}

<style>
    /* ── Master Dashboard Layout ───────────────────────────────── */
    .master-dashboard {
        padding: 2rem 2.25rem;
        max-width: 1200px;
        font-family: 'Outfit', 'Segoe UI', sans-serif;
    }

    /* Hero header strip */
    .master-hero {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: linear-gradient(135deg, #1a237e 0%, #283593 60%, #3949ab 100%);
        border-radius: 20px;
        padding: 2rem 2.5rem;
        margin-bottom: 2rem;
        color: #fff;
        box-shadow: 0 8px 32px rgba(26, 35, 126, 0.2);
    }

    .master-title {
        font-size: 2.25rem;
        font-weight: 800;
        margin: 0 0 0.35rem;
        letter-spacing: -0.5px;
        color: #fff;
    }

    .master-subtitle {
        margin: 0;
        font-size: 0.975rem;
        color: rgba(255, 255, 255, 0.78);
        font-weight: 400;
    }

    .master-hero-badge {
        width: 72px;
        height: 72px;
        background: rgba(255, 255, 255, 0.15);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: #fff;
        flex-shrink: 0;
        backdrop-filter: blur(4px);
    }

    /* ── Module Cards Grid ─────────────────────────────────────── */
    .module-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.1rem;
    }

    .module-card {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        padding: 1.4rem 1.5rem;
        background: #ffffff;
        border: 1px solid #e0e2ec;
        border-radius: 18px;
        text-decoration: none;
        color: #1b1b1f;
        transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }

    /* Subtle left-accent bar using ::before */
    .module-card::before {
        content: '';
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 5px;
        border-radius: 18px 0 0 18px;
        transition: width 0.18s ease;
    }

    .module-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 28px rgba(0, 0, 0, 0.09);
        border-color: transparent;
    }

    .module-card:hover::before { width: 6px; }

    /* Per-module accent colors */
    .module-card.company::before    { background: #008080; }
    .module-card.financial::before  { background: #4a90e2; }
    .module-card.payroll::before    { background: #3a7a52; }
    .module-card.export::before     { background: #c05800; }
    .module-card.stock::before      { background: #7a3abf; }
    .module-card.production::before { background: #bf3a3a; }
    .module-card.setups::before     { background: #44474f; }

    .module-card.company:hover    { box-shadow: 0 8px 28px rgba(0, 128, 128, 0.14); }
    .module-card.financial:hover  { box-shadow: 0 8px 28px rgba(74, 144, 226, 0.14); }
    .module-card.payroll:hover    { box-shadow: 0 8px 28px rgba(58, 122, 82, 0.14); }
    .module-card.export:hover     { box-shadow: 0 8px 28px rgba(192, 88, 0, 0.14); }
    .module-card.stock:hover      { box-shadow: 0 8px 28px rgba(122, 58, 191, 0.14); }
    .module-card.production:hover { box-shadow: 0 8px 28px rgba(191, 58, 58, 0.14); }
    .module-card.setups:hover     { box-shadow: 0 8px 28px rgba(68, 71, 79, 0.14); }

    /* Icon bubble */
    .module-card-icon {
        width: 54px;
        height: 54px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .company     .module-card-icon { background: #e0f2f1; color: #004d40; }
    .financial  .module-card-icon { background: #dbeafe; color: #1d4ed8; }
    .payroll    .module-card-icon { background: #dcf5e7; color: #166534; }
    .export     .module-card-icon { background: #fde8d0; color: #9a3700; }
    .stock      .module-card-icon { background: #ede0f7; color: #5b21b6; }
    .production .module-card-icon { background: #fde8e8; color: #991b1b; }
    .setups     .module-card-icon { background: #f1f3f4; color: #44474f; }

    /* Text body */
    .module-card-body {
        flex: 1;
        min-width: 0;
    }

    .module-card-title {
        font-size: 1.05rem;
        font-weight: 700;
        margin: 0 0 0.2rem;
        color: #1b1b1f;
    }

    .module-card-desc {
        font-size: 0.82rem;
        color: #44474f;
        margin: 0;
        line-height: 1.4;
    }

    .module-card-metrics {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-top: 0.35rem;
        font-size: 0.76rem;
        color: #5c5e66;
    }

    .metric-separator {
        color: #c4c6d0;
    }

    /* Arrow chevron */
    .module-card-arrow {
        color: #c4c6d0;
        font-size: 0.9rem;
        flex-shrink: 0;
        transition: color 0.18s ease, transform 0.18s ease;
    }

    .module-card:hover .module-card-arrow {
        transform: translateX(3px);
        color: #44474f;
    }

    /* Responsive */
    @@media (max-width: 640px) {
        .master-dashboard { padding: 1.25rem; }
        .master-hero { padding: 1.5rem 1.25rem; }
        .master-title { font-size: 1.65rem; }
        .module-grid { grid-template-columns: 1fr; }
    }
</style>
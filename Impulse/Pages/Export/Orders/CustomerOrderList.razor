@page "/export/customer-order-list"
@attribute [Authorize]
@using DataAccessLibrary.Models.ViewModels.Export
@using Impulse.Services
@using Blazored.Typeahead
@using BlazorContextMenu

<PageTitle>Customer Order List</PageTitle>

<div class="container-fluid py-2" style="font-family: 'Calibri', 'Segoe UI', sans-serif;">
    <div class="card border-0 shadow-sm" style="background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(10px); border-radius: 12px;">
        <div class="card-body pt-3">

            <!-- ── Filter Toolbar ── -->
            <div class="row g-2 mb-3 align-items-end">
                <!-- Title -->
                <div class="col-auto d-flex align-items-end pb-1">
                    <h5 class="mb-0 fw-bold text-dark-emphasis">
                        <i class="fas fa-list-alt text-primary me-2"></i>
                        Order List
                    </h5>
                </div>

                <!-- Company -->
                <div class="col-md-2">
                    <label class="form-label fw-bold text-secondary mb-1" style="font-size:0.8rem;">Company</label>
                    <BlazoredTypeahead SearchMethod="SearchCompanies"
                                       EnableDropDown="true"
                                       Data="companies"
                                       TValue="CompanyLookupModel"
                                       TItem="CompanyLookupModel"
                                       Value="selectedCompanyFilter"
                                       ValueChanged="OnCompanyChanged"
                                       ValueExpression="@(() => selectedCompanyFilter)"
                                       Placeholder="All Companies"
                                       MaximumSuggestions="1000">
                        <SelectedTemplate Context="selectedComp">
                            @selectedComp?.CompanyName
                        </SelectedTemplate>
                        <ResultTemplate Context="comp">
                            @comp.CompanyName
                        </ResultTemplate>
                    </BlazoredTypeahead>
                </div>

                <!-- Customer -->
                <div class="col-md-2">
                    <label class="form-label fw-bold text-secondary mb-1" style="font-size:0.8rem;">Customer</label>
                    <BlazoredTypeahead SearchMethod="SearchCustomers"
                                       EnableDropDown="true"
                                       Data="customers"
                                       TValue="CustomerLookupModel"
                                       TItem="CustomerLookupModel"
                                       Value="selectedCustomerFilter"
                                       ValueChanged="OnCustomerChanged"
                                       ValueExpression="@(() => selectedCustomerFilter)"
                                       Placeholder="All Customers"
                                       MaximumSuggestions="1000">
                        <SelectedTemplate Context="selectedCust">
                            @selectedCust?.Name
                        </SelectedTemplate>
                        <ResultTemplate Context="cust">
                            @cust.Name
                        </ResultTemplate>
                    </BlazoredTypeahead>
                </div>

                <!-- Country -->
                <div class="col-md-1">
                    <label class="form-label fw-bold text-secondary mb-1" style="font-size:0.8rem;">Country</label>
                    <select class="form-select form-select-sm" value="@selectedCountryFilter" @onchange="OnCountryChanged">
                        <option value="<All Countries>">&lt;All Countries&gt;</option>
                        @foreach (var c in countries)
                        {
                            <option value="@c">@c</option>
                        }
                    </select>
                </div>

                <!-- Order Type -->
                <div class="col-md-1">
                    <label class="form-label fw-bold text-secondary mb-1" style="font-size:0.8rem;">Order Type</label>
                    <select class="form-select form-select-sm" value="@selectedOrderType" @onchange="OnOrderTypeChanged">
                        <option value="<All Types>">&lt;All Types&gt;</option>
                        <option value="Stock Order">Stock Order</option>
                        <option value="Sample Order">Sample Order</option>
                        <option value="Customer Order">Customer Order</option>
                        <option value="Replacement Order">Replacement Order</option>
                    </select>
                </div>

                <!-- Status Filter -->
                <div class="col-md-1">
                    <label class="form-label fw-bold text-secondary mb-1" style="font-size:0.8rem;">Status</label>
                    <select class="form-select form-select-sm" value="@selectedStatusFilter" @onchange="OnStatusFilterChanged">
                        <option value="0">&lt;Unshipped&gt;</option>
                        <option value="1">&lt;Shipped&gt;</option>
                        <option value="2">&lt;Cancelled&gt;</option>
                        <option value="3">&lt;Hold&gt;</option>
                        <option value="4">&lt;All Orders&gt;</option>
                    </select>
                </div>

                <!-- Date Range picker -->
                <div class="col-md-2 d-flex gap-1">
                    <div>
                        <label class="form-label fw-bold text-secondary mb-1" style="font-size:0.8rem;">From</label>
                        <input type="date" class="form-control form-control-sm" @bind="dtFrom" />
                    </div>
                    <div>
                        <label class="form-label fw-bold text-secondary mb-1" style="font-size:0.8rem;">To</label>
                        <input type="date" class="form-control form-control-sm" @bind="dtTo" />
                    </div>
                </div>

                <!-- Date Filter Switch Check -->
                <div class="col-auto d-flex align-items-center gap-2 pb-1">
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" role="switch" id="filterByDeliveryDTCheck" checked="@filterByDeliveryDT" @onchange="OnFilterByDeliveryDTChanged">
                        <label class="form-check-label text-dark-emphasis fw-semibold" for="filterByDeliveryDTCheck" style="font-size:0.82rem;">Filter by Delivery Date</label>
                    </div>
                </div>

                <!-- Search and Options -->
                <div class="col-md-2">
                    <label class="form-label fw-bold text-secondary mb-1" style="font-size:0.8rem;"><i class="fas fa-search me-1"></i>Search</label>
                    <input type="text" class="form-control form-control-sm" placeholder="Order No, internal ref, company..." @bind="searchText" @bind:event="oninput" />
                </div>

                <div class="col-auto d-flex align-items-end gap-1 pb-1">
                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="RefreshList" title="Refresh List">
                        <i class="fas fa-sync-alt"></i>
                    </button>
                    <button type="button" class="btn btn-primary btn-sm" id="optionsBarMenuButton" @onclick="OpenOptionsBarMenu" title="Reports Options">
                        <i class="fas fa-print me-1"></i> Reports
                    </button>
                </div>
            </div>

            <!-- Highlighted Selected Order info -->
            @if (highlightedOrder != null)
            {
                <div class="mb-3">
                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2 rounded-pill">
                        Selected Order: <strong>@highlightedOrder.OrderNo</strong> (@highlightedOrder.CompanyName)
                    </span>
                </div>
            }

            <!-- Unified List Table -->
            <div class="row">
                <div class="col-12">
                    @if (isLoading)
                    {
                        <div class="d-flex align-items-center justify-content-center py-5">
                            <div class="spinner-border text-primary me-2" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <span class="text-secondary fw-semibold">Loading orders...</span>
                        </div>
                    }
                    else
                    {
                        <div class="card border border-light-subtle rounded-3 overflow-hidden shadow-xs">
                            <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
                                <table class="table table-hover table-sm align-middle mb-0" style="font-size: 0.88rem;">
                                    <thead class="table-light text-secondary sticky-top" style="font-size: 0.78rem; text-transform: uppercase; z-index: 2; box-shadow: 0 1px 0 #dee2e6;">
                                        <tr>
                                            <th style="width: 50px;" class="text-center">S#</th>
                                            <th>Company</th>
                                            <th>Customer</th>
                                            <th>Country</th>
                                            <th>Order #</th>
                                            <th>Type</th>
                                            <th>Int. Ref #</th>
                                            <th class="text-center">Order DT</th>
                                            <th class="text-center">Delivery DT</th>
                                            <th class="text-end">Order Amt</th>
                                            <th class="text-end">Bal. Amt</th>
                                            <th class="text-center">Status</th>
                                            <th class="text-end">Weight</th>
                                            <th class="text-center">Qty</th>
                                            <th class="text-center">Balance</th>
                                            <th class="text-center">Articles</th>
                                            <th class="text-center">App. Status</th>
                                            <th style="width: 80px;" class="text-center">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (!allOrders.Any())
                                        {
                                            <tr>
                                                <td colspan="18" class="text-center text-muted py-4">No customer orders found matching these filters.</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            int idx = 1;
                                            @foreach (var order in GetFilteredOrders())
                                            {
                                                var currentOrder = order;
                                                bool isSelected = highlightedOrder?.OrderNo == order.OrderNo;
                                                <tr @onclick="() => HighlightOrder(currentOrder)"
                                                    @oncontextmenu="(e) => OpenRowMenu(e, currentOrder)"
                                                    @oncontextmenu:preventDefault="true"
                                                    class="clickable-row @(isSelected ? "table-primary" : "")"
                                                    style="cursor: pointer; transition: background 0.15s ease;">
                                                    <td class="text-center text-secondary">@(idx++)</td>
                                                    <td>@order.CompanyName</td>
                                                    <td>@order.CustCode</td>
                                                    <td>@order.Country</td>
                                                    <td class="fw-semibold">@order.OrderNo</td>
                                                    <td>@order.OrderType</td>
                                                    <td>@order.InternalRefNo</td>
                                                    <td class="text-center">@order.DT.ToString("dd-MMM-yyyy")</td>
                                                    <td class="text-center">@order.DeliveryDT.ToString("dd-MMM-yyyy")</td>
                                                    <td class="text-end fw-semibold text-primary">@order.Curr @order.OrderAmt.ToString("N2")</td>
                                                    <td class="text-end text-danger">@order.Curr @((order.OrderAmt - (order.TotalShippedAmt ?? 0)).ToString("N2"))</td>
                                                    <td class="text-center">
                                                        <span class="badge @(order.OrderStatus == "Shipped" ? "bg-success" : (order.OrderStatus == "Cancelled" ? "bg-danger" : (order.OrderStatus == "Hold" ? "bg-warning text-dark" : "bg-info")))">
                                                            @order.OrderStatus
                                                        </span>
                                                    </td>
                                                    <td class="text-end">@order.TotalWeight.ToString("N2")</td>
                                                    <td class="text-center fw-semibold">@order.TotalOrderQty</td>
                                                    <td class="text-center text-danger">@order.TotalBalanceQty</td>
                                                    <td class="text-center">@order.TotalArticles</td>
                                                    <td class="text-center fw-bold">@order.PurchasePlanStatus</td>
                                                    <td class="text-center" @onclick:stopPropagation="true">
                                                        <button type="button" class="btn btn-outline-secondary btn-xs py-0 px-2" style="font-size: 0.75rem;" @onclick="(e) => OpenRowMenu(e, currentOrder)">Manage</button>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Grand Total Footer Banner -->
                        <div class="row align-items-center mt-3 p-3 bg-light rounded-3 border g-2">
                            <div class="col-md-6 d-flex align-items-center">
                                <span class="fw-bold text-dark-emphasis"><i class="fas fa-file-invoice-dollar text-secondary me-2"></i> Total Active Orders Amount (PKR equivalent):</span>
                                <span class="badge bg-primary text-white ms-2 px-3 py-2 rounded-pill fs-6">Rs. @totalAmtPKR.ToString("N2")</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Modal: Password Prompt Dialog ── -->
@if (showPasswordModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.45); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 12px;">
                <div class="modal-header bg-warning text-dark border-0 py-2" style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
                    <h6 class="modal-title fw-bold"><i class="fas fa-lock me-2"></i>Authorization Required</h6>
                    <button type="button" class="btn-close" @onclick="() => showPasswordModal = false"></button>
                </div>
                <div class="modal-body py-3">
                    <p class="text-secondary" style="font-size: 0.85rem;">Please enter password for <strong>@passwordSettingName</strong>:</p>
                    <input type="password" class="form-control form-control-sm" @bind="enteredPassword" placeholder="Password..." />
                    @if (!string.IsNullOrEmpty(passwordError))
                    {
                        <div class="text-danger mt-1" style="font-size: 0.75rem;">@passwordError</div>
                    }
                </div>
                <div class="modal-footer border-0 pt-0 pb-3">
                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="() => showPasswordModal = false">Cancel</button>
                    <button type="button" class="btn btn-primary btn-sm" @onclick="VerifyPasswordAndExecute">Submit</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- ── Modal: Remarks Prompt Dialog ── -->
@if (showRemarksModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.45); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 12px;">
                <div class="modal-header bg-primary text-white border-0 py-2" style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
                    <h6 class="modal-title fw-bold"><i class="fas fa-comment me-2"></i>@remarksModalTitle</h6>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showRemarksModal = false"></button>
                </div>
                <div class="modal-body py-3">
                    <label class="form-label fw-bold text-secondary mb-1">Remarks / Reason</label>
                    <textarea class="form-control" rows="3" @bind="enteredRemarks" placeholder="Enter status remarks..."></textarea>
                </div>
                <div class="modal-footer border-0 pt-0 pb-3">
                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="() => showRemarksModal = false">Cancel</button>
                    <button type="button" class="btn btn-primary btn-sm" @onclick="SaveRemarks">Save</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- ── Context Menu: Row Actions ── -->
<ContextMenu Id="rowContextMenu" UseDefaultEventHandlers="true" Template="Win11Style">
    @if (context.Data is CustomerOrderListItemModel order)
    {
        <div class="win11-section-header">Order No: @order.OrderNo</div>
        <Item class="win11-menu-item" OnClick="@(() => EditOrder(order.OrderNo))">
            <i class="fas fa-edit fa-fw win11-icon text-primary"></i> Edit Order
        </Item>
        <Item class="win11-menu-item" OnClick="@(() => CopyOrder(order.OrderNo))">
            <i class="fas fa-copy fa-fw win11-icon text-secondary"></i> Copy Order
        </Item>
        <Item class="win11-menu-item" OnClick="@(() => DeleteOrder(order.OrderNo))">
            <i class="fas fa-trash-alt fa-fw win11-icon text-danger"></i> Delete Order
        </Item>

        <div class="win11-divider"></div>
        <div class="win11-section-header">Status Management</div>
        @if (order.Cancelled == 0)
        {
            <Item class="win11-menu-item" OnClick="@(() => CancelOrder(order))">
                <i class="fas fa-ban fa-fw win11-icon text-danger"></i> Cancel Order
            </Item>
            <Item class="win11-menu-item" OnClick="@(() => HoldOrder(order))">
                <i class="fas fa-pause fa-fw win11-icon text-warning"></i> Hold Order
            </Item>
            <Item class="win11-menu-item" OnClick="@(() => MarkAsShipped(order))">
                <i class="fas fa-check-double fa-fw win11-icon text-success"></i> Mark As Shipped
            </Item>
        }
        else
        {
            <Item class="win11-menu-item" OnClick="@(() => UnCancelUnHoldOrder(order.OrderNo))">
                <i class="fas fa-undo fa-fw win11-icon text-success"></i> Restore Order (Un-Cancel/Un-Hold)
            </Item>
        }

        <div class="win11-divider"></div>
        <div class="win11-section-header">Printing &amp; Slips</div>
        <Item class="win11-menu-item" OnClick="@(() => PrintOrderWrangler(order.OrderNo))">
            <i class="fas fa-print fa-fw win11-icon"></i> Print Order
        </Item>
        <Item class="win11-menu-item" OnClick="@(() => PrintOrderWrangler(order.OrderNo, reportType: 99))">
            <i class="fas fa-sticky-note fa-fw win11-icon"></i> Print Order Slip
        </Item>
        <Item class="win11-menu-item" OnClick="@(() => PrintOrderWrangler(order.OrderNo, reportType: 98))">
            <i class="fas fa-image fa-fw win11-icon"></i> Print Order (Pictures)
        </Item>
        <Item class="win11-menu-item" OnClick="@(() => PrintOrderWrangler(order.OrderNo, orderStatus: true))">
            <i class="fas fa-info-circle fa-fw win11-icon"></i> Print Order Status
        </Item>
        <Item class="win11-menu-item" OnClick="@(() => PrintOrderWrangler(order.OrderNo, orderDetails: true))">
            <i class="fas fa-align-left fa-fw win11-icon"></i> Print Order (Details)
        </Item>
        <Item class="win11-menu-item" OnClick="@(() => PrintCustomerPO(order.OrderNo))">
            <i class="fas fa-file-invoice fa-fw win11-icon"></i> Print Customer Order
        </Item>

        <div class="win11-divider"></div>
        <div class="win11-section-header">Planning &amp; Manufacturing</div>
        <Item class="win11-menu-item" OnClick="@(() => PrintDeliverySchedule(order.OrderNo))">
            <i class="fas fa-shipping-fast fa-fw win11-icon"></i> Print Delivery Schedule (Balance)
        </Item>
        <Item class="win11-menu-item" OnClick="@(() => PrintMaterialConsumptionSheet(order.OrderNo))">
            <i class="fas fa-box-open fa-fw win11-icon"></i> Material Consumption
        </Item>
        <Item class="win11-menu-item" OnClick="@(() => PrintMaterialConsumptionSheet(order.OrderNo, true))">
            <i class="fas fa-boxes fa-fw win11-icon"></i> Material Consumption (Articlewise)
        </Item>
        <Item class="win11-menu-item" OnClick="@(() => PrintOrderWrangler(order.OrderNo, printBalance: true))">
            <i class="fas fa-balance-scale fa-fw win11-icon"></i> Print Production Order Balance
        </Item>
        <Item class="win11-menu-item" OnClick="@(() => PrintProductionExportCost(order.OrderNo))">
            <i class="fas fa-dollar-sign fa-fw win11-icon"></i> Print Production Export Cost
        </Item>
        <Item class="win11-menu-item" OnClick="@(() => PrintScoreBoard(order.OrderNo))">
            <i class="fas fa-tachometer-alt fa-fw win11-icon"></i> Score Board Report
        </Item>
    }
</ContextMenu>

<!-- ── Context Menu: General Options Bar Reports ── -->
<ContextMenu Id="optionsBarMenu" UseDefaultEventHandlers="true" Template="Win11Style">
    <div class="win11-section-header">General Order Lists</div>
    <Item class="win11-menu-item" OnClick="@(() => PrintOrderList())">
        <i class="fas fa-list fa-fw win11-icon"></i> Print Order List
    </Item>
    <Item class="win11-menu-item" OnClick="@(() => PrintOrderList(balanceListOnly: true))">
        <i class="fas fa-list-ol fa-fw win11-icon"></i> Print Order Balance List
    </Item>

    <div class="win11-divider"></div>
    <div class="win11-section-header">Combined Order Reports</div>
    <Item class="win11-menu-item" OnClick="@(() => PrintCombinedOrderReport(0))">
        <i class="fas fa-table fa-fw win11-icon"></i> Item-wise Combined Report
    </Item>
    <Item class="win11-menu-item" OnClick="@(() => PrintCombinedOrderReport(1))">
        <i class="fas fa-layer-group fa-fw win11-icon"></i> Item Group-wise Combined Report
    </Item>
    <Item class="win11-menu-item" OnClick="@(() => PrintCombinedOrderReport(2))">
        <i class="fas fa-file-signature fa-fw win11-icon"></i> Order-wise Combined Report
    </Item>

    <div class="win11-divider"></div>
    <div class="win11-section-header">Production &amp; Tracking Logs</div>
    <Item class="win11-menu-item" OnClick="@(() => PrintOrderStatusLogReport(false))">
        <i class="fas fa-history fa-fw win11-icon"></i> Order Status Log
    </Item>
    <Item class="win11-menu-item" OnClick="@(() => PrintOrderStatusLogReport(true))">
        <i class="fas fa-calendar-check fa-fw win11-icon"></i> Order Status Log (New/Extended)
    </Item>
    <Item class="win11-menu-item" OnClick="@(() => PrintPlanningPurchaseLogReport())">
        <i class="fas fa-shopping-basket fa-fw win11-icon"></i> Planning Purchase Log Sheet
    </Item>
    <Item class="win11-menu-item" OnClick="@(() => PrintProductionTimeline())">
        <i class="fas fa-chart-line fa-fw win11-icon"></i> Production Timeline Report
    </Item>
    <Item class="win11-menu-item" OnClick="@(() => PrintUrgentRequestReport())">
        <i class="fas fa-exclamation-circle fa-fw win11-icon text-danger"></i> Urgent Request Report
    </Item>
    <Item class="win11-menu-item" OnClick="@(() => PrintOrdersLogSheetReport())">
        <i class="fas fa-clipboard-list fa-fw win11-icon"></i> Orders Log Sheet
    </Item>
</ContextMenu>

<style>
    .clickable-row:hover {
        background-color: rgba(192, 88, 0, 0.05) !important;
    }
    .btn-xs {
        padding: 0.15rem 0.4rem;
        font-size: 0.75rem;
        border-radius: 4px;
    }
</style>

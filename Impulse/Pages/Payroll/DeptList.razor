@page "/payroll/deptlist"
@attribute [Authorize]
@using DataAccessLibrary.Models.ViewModels.Payroll
@using Impulse.Services

<PageTitle>Department List</PageTitle>

<div class="container-fluid py-2" style="font-family: 'Calibri', 'Segoe UI', sans-serif;">
    <div class="card border-0 shadow-sm" style="background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(10px); border-radius: 12px;">
        <div class="card-body pt-3">
            
            <!-- Toolbar -->
            <div class="row g-2 mb-3 align-items-end">
                <div class="col-auto d-flex align-items-end pb-1">
                    <h5 class="mb-0 fw-bold text-dark-emphasis">
                        <i class="fas fa-building text-primary me-2"></i>
                        Department List
                    </h5>
                </div>

                <!-- Search -->
                <div class="col-md-4">
                    <label class="form-label fw-bold text-secondary mb-1" style="font-size:0.8rem;">
                        <i class="fas fa-search me-1"></i>Search
                    </label>
                    <input type="text" class="form-control form-control-sm" placeholder="Search by ID, Name or Description..." @bind="searchText" @bind:event="oninput" />
                </div>

                <!-- Switches -->
                <div class="col-auto d-flex align-items-center gap-3 pb-1">
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" role="switch" id="showInactiveCheck" checked="@showInactive" @onchange="OnShowInactiveChanged">
                        <label class="form-check-label text-dark-emphasis fw-semibold" for="showInactiveCheck" style="font-size:0.85rem;">Show Inactive</label>
                    </div>
                </div>

                <!-- Actions -->
                <div class="col d-flex align-items-end justify-content-end gap-2 pb-1">
                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="RefreshList" title="Refresh List">
                        <i class="fas fa-sync-alt"></i>
                    </button>
                    <button type="button" class="btn btn-primary btn-sm" @onclick="OpenAddModal">
                        <i class="fas fa-plus me-1"></i> Add New Department
                    </button>
                    <button type="button" class="btn btn-outline-primary btn-sm" @onclick="PrintDepartmentList">
                        <i class="fas fa-print me-1"></i> Print List
                    </button>
                </div>
            </div>

            <!-- List Grid -->
            @if (isLoading)
            {
                <div class="d-flex align-items-center justify-content-center py-5">
                    <div class="spinner-border text-primary me-2" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <span class="text-secondary fw-semibold">Loading data...</span>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-sm align-middle mb-0" style="font-size: 0.9rem;">
                        <thead class="table-light text-secondary" style="font-size: 0.8rem; text-transform: uppercase;">
                            <tr>
                                <th class="ps-3" style="width: 100px;">Dept ID</th>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Salary Acc</th>
                                <th>Accrued Acc</th>
                                <th class="text-center" style="width: 100px;">Status</th>
                                <th class="text-center" style="width: 150px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (FilteredDepartments.Count == 0)
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-4">No departments found.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var dept in FilteredDepartments)
                                {
                                    <tr style="cursor: pointer; transition: background 0.15s ease;">
                                        <td class="ps-3 fw-semibold">
                                            <span style="color: @(dept.Active ? ConvertWin32ColorToHex(dept.Color) : "gray"); text-decoration: @(dept.Active ? "none" : "line-through");">
                                                @dept.DeptID
                                            </span>
                                        </td>
                                        <td>
                                            <span class="fw-semibold" style="color: @(dept.Active ? "#2b3035" : "red");">
                                                @dept.Name
                                            </span>
                                        </td>
                                        <td class="text-secondary">@dept.Description</td>
                                        <td>@dept.SalaryAccNo</td>
                                        <td>@dept.AccruedAccNo</td>
                                        <td class="text-center">
                                            @if (dept.Active)
                                            {
                                                <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill">Inactive</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group">
                                                <button type="button" class="btn btn-outline-primary btn-sm px-2" @onclick="() => OpenEditModal(dept.DeptID)">
                                                    <i class="fas fa-edit"></i> Edit
                                                </button>
                                                <button type="button" class="btn btn-outline-secondary btn-sm px-2" @onclick="() => ToggleActive(dept)">
                                                    @if (dept.Active)
                                                    {
                                                        <span><i class="fas fa-ban text-danger"></i> Deactivate</span>
                                                    }
                                                    else
                                                    {
                                                        <span><i class="fas fa-check text-success"></i> Activate</span>
                                                    }
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }

        </div>
    </div>
</div>

<!-- Embedded Department Editor Modal -->
<NewDepartment @ref="editorModal" OnSaved="OnSaved" OnCancelled="OnCancelled" />

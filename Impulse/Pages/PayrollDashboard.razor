@page "/payroll"
@attribute [Authorize]

<PageTitle>Payroll Dashboard</PageTitle>

<div class="dashboard-shell">
    <div class="dashboard-hero">
        <div class="dashboard-icon-wrap" style="background:#dce8d4; color:#1a4731;">
            <i class="fas fa-users-gear"></i>
        </div>
        <div>
            <h1 class="dashboard-title">Payroll</h1>
            <p class="dashboard-subtitle">Employees, departments &amp; payroll processing</p>
        </div>
    </div>

    <div class="dashboard-modules">
        <a href="/payroll/employeelist" class="dash-card">
            <i class="fas fa-user-tie"></i>
            <span>Employee List</span>
        </a>
        <a href="/payroll/employeelist?contractorsOnly=true" class="dash-card">
            <i class="fas fa-user-clock"></i>
            <span>Temp. Employee List</span>
        </a>
        <a href="/payroll/deptlist" class="dash-card">
            <i class="fas fa-building"></i>
            <span>Departments List</span>
        </a>
    </div>
</div>

<style>
    .dashboard-shell { padding: 2rem; max-width: 1100px; }
    .dashboard-hero { display: flex; align-items: center; gap: 1.25rem; margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 2px solid #e0e2ec; }
    .dashboard-icon-wrap { width: 64px; height: 64px; border-radius: 18px; background: #dce8d4; display: flex; align-items: center; justify-content: center; font-size: 1.75rem; color: #1a4731; flex-shrink: 0; }
    .dashboard-title { font-size: 2rem; font-weight: 700; color: #1b1b1f; margin: 0; line-height: 1.2; }
    .dashboard-subtitle { color: #44474f; margin: 0.25rem 0 0; font-size: 0.95rem; }
    .dashboard-modules { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 1rem; }
    .dash-card { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.75rem; padding: 1.5rem 1rem; background: #ffffff; border: 1px solid #e0e2ec; border-radius: 16px; text-decoration: none; color: #1b1b1f; font-weight: 500; font-size: 0.875rem; text-align: center; transition: background-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease; cursor: pointer; }
    .dash-card i { font-size: 1.75rem; color: #3a7a52; }
    .dash-card:hover { background: #edf7f0; box-shadow: 0 4px 16px rgba(58, 122, 82, 0.12); transform: translateY(-2px); color: #1a4731; }
    .dash-card:hover i { color: #1a4731; }
</style>

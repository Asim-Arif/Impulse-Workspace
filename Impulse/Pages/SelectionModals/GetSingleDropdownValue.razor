@if (IsVisible)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">@Title</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="Cancel"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label fw-bold">@Label</label>
                    <select class="form-select" @bind="SelectedValue">
                        <option value="">-- Select One --</option>
                        @foreach (var item in Items)
                        {
                            <option value="@item.DropDownValue_ID">@item.DropDownValue_Description</option>
                        }
                    </select>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="Cancel">Cancel</button>
                    <button class="btn btn-primary" @onclick="Confirm"
                            disabled="@(string.IsNullOrEmpty(SelectedValue))">
                        OK
                    </button>
                </div>
            </div>
        </div>
    </div>
}
@page "/financial"
@attribute [Authorize]

<PageTitle>Financial Dashboard</PageTitle>

<div class="dashboard-shell">
    <div class="dashboard-hero">
        <div class="dashboard-icon-wrap">
            <i class="fas fa-chart-line"></i>
        </div>
        <div>
            <h1 class="dashboard-title">Financial</h1>
            <p class="dashboard-subtitle">Vouchers, ledgers, reports &amp; financial statements</p>
        </div>
    </div>

    <div class="dashboard-modules">
        <a href="/accounts/chartofaccounts" class="dash-card">
            <i class="fas fa-file-invoice"></i>
            <span>Chart of Accounts</span>
        </a>
        <a href="/accounts/voucherslist" class="dash-card">
            <i class="fas fa-list"></i>
            <span>Vouchers List</span>
        </a>
        <a href="/accounts/accountsledger" class="dash-card">
            <i class="fas fa-book-open"></i>
            <span>Accounts Ledger</span>
        </a>
        <a href="/accounts/trialbalance" class="dash-card">
            <i class="fas fa-scale-balanced"></i>
            <span>Trial Balance</span>
        </a>
        <a href="/accounts/banklist" class="dash-card">
            <i class="fa fa-university"></i>
            <span>Bank List</span>
        </a>
        <a href="/accounts/bankbalancestatement" class="dash-card">
            <i class="fas fa-piggy-bank"></i>
            <span>Bank Balance Statement</span>
        </a>
    </div>
</div>

<style>
    .dashboard-shell {
        padding: 2rem;
        max-width: 1100px;
    }

    .dashboard-hero {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        margin-bottom: 2.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 2px solid #e0e2ec;
    }

    .dashboard-icon-wrap {
        width: 64px;
        height: 64px;
        border-radius: 18px;
        background: #d3e3fd;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        color: #041e49;
        flex-shrink: 0;
    }

    .dashboard-title {
        font-size: 2rem;
        font-weight: 700;
        color: #1b1b1f;
        margin: 0;
        line-height: 1.2;
    }

    .dashboard-subtitle {
        color: #44474f;
        margin: 0.25rem 0 0;
        font-size: 0.95rem;
    }

    .dashboard-modules {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
        gap: 1rem;
    }

    .dash-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        padding: 1.5rem 1rem;
        background: #ffffff;
        border: 1px solid #e0e2ec;
        border-radius: 16px;
        text-decoration: none;
        color: #1b1b1f;
        font-weight: 500;
        font-size: 0.875rem;
        text-align: center;
        transition: background-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
        cursor: pointer;
    }

    .dash-card i {
        font-size: 1.75rem;
        color: #4a90e2;
    }

    .dash-card:hover {
        background: #f0f4ff;
        box-shadow: 0 4px 16px rgba(74, 144, 226, 0.12);
        transform: translateY(-2px);
        color: #041e49;
    }

    .dash-card:hover i {
        color: #041e49;
    }
</style>
